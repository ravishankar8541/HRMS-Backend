# Dependency directories
node_modules/
jspm_packages/

# Puppeteer / Chromium Cache
# Puppeteer downloads a large browser binary (~150MB+); don't track it!
.local-chromium/
.cache/puppeteer/
.cache/

# Environment Variables (CRITICAL)
# Protects your EMAIL_USER and EMAIL_PASS for Titan Email
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime / Temporary Files
# If you save PDFs locally for testing before sending them
*.pdf
temp/
dist/
build/

# Operating System Files
.DS_Store
Thumbs.db

# Editor / IDE Folders
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj

